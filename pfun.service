[Unit]
Description=P-Fun F1 Prediction Challenge
After=network.target

[Service]
Type=simple
User=pfun
Group=pfun
WorkingDirectory=/opt/pfun
Environment=PORT=80
AmbientCapabilities=CAP_NET_BIND_SERVICE
ExecStart=/opt/pfun/venv/bin/gunicorn --bind 0.0.0.0:80 app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
